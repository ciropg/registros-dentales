generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DENTIST
  ASSISTANT
  RECEPTIONIST
  DEMO_ADMIN
  DEMO_DENTIST
  DEMO_ASSISTANT
  DEMO_RECEPTIONIST
}


enum TreatmentStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELED
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum AppointmentStatus {
  SCHEDULED
  ATTENDED
  NO_SHOW
  RESCHEDULED
  CANCELED
}

model Role {
  id          String   @id @default(cuid())
  code        UserRole @unique
  name        String
  description String?
  isDemo      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  passwordHash   String
  roleId         String
  role           UserRole
  isDemo         Boolean     @default(false)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  roleDefinition Role        @relation(fields: [roleId], references: [id])
  treatments     Treatment[] @relation("DentistTreatments")
  auditLogs      AuditLog[]

  @@index([isDemo])
  @@index([roleId])
}

model Patient {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  documentNumber String?
  phone          String?
  email          String?
  birthDate      DateTime?
  notes          String?
  isDemo         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  treatments     Treatment[]
  appointments   Appointment[]
  photos         PatientPhoto[]

  @@index([isDemo])
  @@unique([documentNumber, isDemo])
  @@unique([firstName, lastName, isDemo])
}

model Treatment {
  id               String          @id @default(cuid())
  patientId        String
  dentistId        String?
  title            String
  diagnosis        String
  startDate        DateTime
  estimatedEndDate DateTime
  actualEndDate    DateTime?
  status           TreatmentStatus @default(PLANNED)
  notes            String?
  isDemo           Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  patient          Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dentist          User?           @relation("DentistTreatments", fields: [dentistId], references: [id], onDelete: SetNull)
  phases           TreatmentPhase[]
  appointments     Appointment[]

  @@index([patientId])
  @@index([dentistId])
  @@index([status])
  @@index([isDemo])
}

model TreatmentPhase {
  id            String      @id @default(cuid())
  treatmentId   String
  name          String
  phaseOrder    Int
  weight        Int         @default(1)
  status        PhaseStatus @default(PENDING)
  plannedDate   DateTime?
  completedDate DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  treatment     Treatment   @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId])
  @@unique([treatmentId, phaseOrder])
}

model Appointment {
  id               String            @id @default(cuid())
  patientId        String
  treatmentId      String?
  scheduledAt      DateTime
  status           AppointmentStatus @default(SCHEDULED)
  reason           String
  notes            String?
  rescheduledFromId String?
  isDemo           Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment        Treatment?        @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  rescheduledFrom  Appointment?      @relation("AppointmentReschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  reschedules      Appointment[]     @relation("AppointmentReschedule")

  @@index([patientId])
  @@index([treatmentId])
  @@index([scheduledAt])
  @@index([status])
  @@index([isDemo])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  entityType  String
  entityId    String
  action      String
  description String?
  metadata    String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

model PatientPhoto {
  id               String   @id @default(cuid())
  patientId        String
  publicId         String   @unique
  secureUrl        String
  originalFilename String?
  description      String?
  width            Int?
  height           Int?
  bytes            Int?
  format           String?
  isDemo           Boolean  @default(false)
  createdAt        DateTime @default(now())
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, isDemo, createdAt])
  @@index([isDemo, createdAt])
}

